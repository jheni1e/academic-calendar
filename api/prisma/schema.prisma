model Room {
  room_id     Int     @id @default(autoincrement())
  title String @unique
  capacity    Int
  description String?
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reservations Reservation[]
  subjectRooms SubjectRoom[]

  @@index([is_active])
}

model Reservation {
  reservation_id Int               @id @default(autoincrement())
  description    String?
  // status         ReservationStatus
  room_id        Int
  event_id       Int               @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  room  Room  @relation(fields: [room_id], references: [room_id])
  event Event @relation(fields: [event_id], references: [event_id])

  @@index([room_id])
  @@index([event_id])
  // @@index([room_id, status])
}

model Participation {
  participation_id Int                 @id @default(autoincrement())
  user_id          Int
  // event_role_id    Int
  event_id         Int
  status           ParticipationStatus

  user       User      @relation(fields: [user_id], references: [user_id])
  // event_role EventRole @relation(fields: [event_role_id], references: [event_role_id])
  event      Event     @relation(fields: [event_id], references: [event_id])

  @@unique([user_id, event_id], name: "user_event_unique")
  @@index([user_id])
  @@index([event_id])
  // @@index([event_role_id])
}
