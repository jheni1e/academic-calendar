generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  DECLINED
  ATTENDED // Optional
  CANCELLED
}

model User {
  user_id  Int      @id @default(autoincrement())
  user_edv Int      @unique
  name     String
  birthday DateTime
  password String

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  assignments    Assignment[]
  participations Participation[]
  subjects       SubjectInstructor[]
  classes        ClassUser[]
  createdEvents  Event[]             @relation("CreatedEvents")
}

model ClassUser {
  class_user_id Int @id @default(autoincrement())
  class_id      Int
  user_id       Int

  class Class @relation(fields: [class_id], references: [class_id])
  user  User  @relation(fields: [user_id], references: [user_id])

  @@unique([class_id, user_id])
  @@index([user_id])
  @@index([class_id])
}

model Role {
  role_id     Int          @id @default(autoincrement())
  name        String       @unique
  assignments Assignment[]
}

model Assignment {
  assignment_id Int @id @default(autoincrement())
  role_id       Int
  user_id       Int

  role Role @relation(fields: [role_id], references: [role_id])
  user User @relation(fields: [user_id], references: [user_id])

  @@unique([role_id, user_id])
  @@index([user_id])
  @@index([role_id])
}

model Class {
  class_id  Int     @id @default(autoincrement())
  name      String
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class_users ClassUser[]
  subjects    Subject[]
  events      Event[]
}

model Subject {
  subject_id Int      @id @default(autoincrement())
  name       String
  workload   Int
  start_date DateTime
  end_date   DateTime
  class_id   Int
  events     Event[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  responsables SubjectInstructor[]
  // requirements SubjectRequirement[]

  class        Class         @relation(fields: [class_id], references: [class_id])
  subjectRooms SubjectRoom[]

  @@index([class_id])
}

model SubjectInstructor {
  subject_instructor_id Int @id @default(autoincrement())
  subject_id            Int
  instructor_id         Int

  subject    Subject @relation(fields: [subject_id], references: [subject_id])
  instructor User    @relation(fields: [instructor_id], references: [user_id])

  @@unique([subject_id, instructor_id], name: "subject_instructor_unique")
  @@index([subject_id])
  @@index([instructor_id])
}

