generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// enum RecurrenceFrequency {
//   DAILY
//   WEEKLY
//   MONTHLY
// }

enum UserRole {
  ADMIN
  INSTRUCTOR
  APPRENTICE
}

enum EventType {
  LESSON
  ASSESSMENT
  FEEDBACK
  EXTERNAL
  PERSONAL
  OTHER
}

enum EventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  DECLINED
  ATTENDED // Optional
  CANCELLED
}

model User {
  user_id  Int      @id @default(autoincrement())
  user_edv Int      @unique
  name     String
  birthday DateTime
  password String
  role UserRole

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // assignments    Assignment[]
  participations Participation[]
  subjectAssignments       SubjectInstructor[]
  classes        ClassUser[]
  createdEvents  Event[]             @relation("CreatedEvents")
  recurrences    Recurrence[]
}

