model Class {
  class_id  Int     @id @default(autoincrement())
  name      String
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class_users ClassUser[]
  subjects    Subject[]
  events      Event[]

  @@index([is_active])
}

model ClassUser {
  class_user_id Int @id @default(autoincrement())
  class_id      Int
  user_id       Int

  class Class @relation(fields: [class_id], references: [class_id])
  user  User  @relation(fields: [user_id], references: [user_id])

  @@unique([class_id, user_id], name: "class_user_unique")
  @@index([user_id])
  @@index([class_id])
}

model Subject {
  subject_id Int      @id @default(autoincrement())
  name       String

  workload   Int
  completed_workload Int

  start_date DateTime
  end_date   DateTime?
  class_id   Int
  // events     Event[]
  is_active  Boolean  @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  responsables SubjectInstructor[]

  class        Class         @relation(fields: [class_id], references: [class_id])
  subjectRooms SubjectRoom[]

  @@index([class_id])
  @@index([is_active])
}

model SubjectInstructor {
  subject_instructor_id Int @id @default(autoincrement())
  subject_id            Int
  instructor_id         Int
  events Event[]

  subject    Subject @relation(fields: [subject_id], references: [subject_id])
  instructor User    @relation(fields: [instructor_id], references: [user_id])

  @@unique([subject_id, instructor_id], name: "subject_instructor_unique")
  @@index([subject_id])
  @@index([instructor_id])
}

model SubjectRoom {
  subject_room_id Int @id @default(autoincrement())
  room_id         Int
  subject_id      Int
  priority        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  subject Subject @relation(fields: [subject_id], references: [subject_id])
  room    Room    @relation(fields: [room_id], references: [room_id])

  @@unique([subject_id, priority])
  @@unique([subject_id, room_id])
  @@index([room_id])
  @@index([subject_id])
}

