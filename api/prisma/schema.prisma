// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  BLOCKED
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  DECLINED
  ATTENDED // Optional
  CANCELLED
}
model User {
  user_id Int @id @default(autoincrement())
  user_edv Int @unique
  name String 
  birthday DateTime
  is_active Boolean @default(true)

  assignments Assignment[]
  participations Participation[]
  subjects SubjectInstructor[]
  classes ClassUser[]
}

model ClassUser {
  class_user_id Int @id @default(autoincrement())
  class_id Int
  user_id Int

  class Class @relation(fields: [class_id], references: [class_id])
  user User @relation(fields: [user_id], references: [user_id])

  @@unique([class_id, user_id])
}

model Role {
  role_id Int @id @default(autoincrement())
  name String @unique
  assignments Assignment[]
}

model Assignment {
  assignment_id Int @id @default(autoincrement())
  role_id Int
  user_id Int

  role Role  @relation(fields: [role_id], references: [role_id])
  user User @relation(fields: [user_id], references: [user_id])

  @@unique([role_id, user_id])
}

model Class {
  class_id Int @id @default(autoincrement())
  name String
  is_active Boolean @default(true)
  class_users ClassUser[]
  subjects Subject[]
}


model Subject {
  subject_id Int @id @default(autoincrement())
  name String
  workload Int
  start_date DateTime
  end_date DateTime
  class_id Int
  events Event[]

  responsables SubjectInstructor[]
  requirements SubjectRequirement[]

  class Class @relation(fields: [class_id], references: [class_id])
}

model SubjectInstructor {
  subject_instructor_id Int @id @default(autoincrement())// @map("subject_responsable_id")
  subject_id Int
  instructor_id Int

  subject Subject @relation(fields: [subject_id], references: [subject_id])
  instructor User @relation(fields: [instructor_id], references: [user_id])

  @@unique([subject_id, instructor_id])
  @@index([subject_id])
  @@index([instructor_id])
}

model SubjectRequirement {
  subject_requirement_id Int @id @default(autoincrement())
  subject_id Int
  feature_id Int

  subject Subject @relation(fields: [subject_id], references: [subject_id])
  feature Feature @relation(fields: [feature_id], references: [feature_id])
  
  @@unique([subject_id, feature_id])
  @@index([subject_id])
  @@index([feature_id])
}

model EventType {
  event_type_id Int @id @default(autoincrement())
  name String @unique
  events Event[]
}

model Event {
  event_id Int @id @default(autoincrement())
  title String
  description String?
  created_at DateTime @default(now())
  event_type_id Int

  subject_id Int?
  class_id Int?

  participations Participation[]
  reservation Reservation?

  event_type EventType @relation(fields: [event_type_id], references: [event_type_id])
  subject Subject? @relation(fields: [subject_id], references: [subject_id])
  class Class? @relation(fields: [class_id], references: [class_id])

  @@index([subject_id])
  @@index([class_id])
  @@index([event_type_id])
}                                  

model Room {
  room_id Int @id @default(autoincrement())
  title String
  capacity Int
  description String?   

  reservations Reservation[]     
  roomFeatures RoomFeature[]
}

model Feature {
  feature_id Int @id @default(autoincrement())
  name String @unique
  
  roomFeatures RoomFeature[]
  subjectRequirements SubjectRequirement[]
}

model RoomFeature {
  room_feature_id Int @id @default(autoincrement())
  room_id Int
  feature_id Int

  room Room @relation(fields: [room_id], references: [room_id])
  feature Feature @relation(fields: [feature_id], references: [feature_id])
  
  @@unique([room_id, feature_id])
  @@index([room_id])
  @@index([feature_id])
}

model Reservation {
  reservation_id Int @id @default(autoincrement())
  description String?
  schedule_start DateTime
  schedule_end DateTime
  status ReservationStatus
  room_id Int
  event_id Int @unique

  room Room @relation(fields: [room_id], references: [room_id])
  event Event @relation(fields: [event_id], references: [event_id])

  @@index([room_id])
  @@index([event_id])
}

model EventRole {
  event_role_id Int @id @default(autoincrement())
  name String @unique
  participations Participation[]
}

model Participation {
  participation_id Int @id @default(autoincrement())
  user_id Int
  event_role_id Int
  event_id Int
  status ParticipationStatus

  user User @relation(fields: [user_id], references: [user_id]) 
  event_role EventRole @relation(fields: [event_role_id], references: [event_role_id])
  event Event @relation(fields: [event_id], references: [event_id])

  @@unique([user_id, event_id])
  @@index([user_id])
  @@index([event_id])
}


 

 