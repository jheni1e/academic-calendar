model EventType {
  event_type_id Int    @id @default(autoincrement())
  name          String @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  events Event[]
}

model Event {
  event_id      Int     @id @default(autoincrement())
  title         String
  description   String?
  event_type_id Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  subject_id Int?
  class_id   Int?
  created_by Int

  participations Participation[]
  reservation    Reservation?

  event_type EventType @relation(fields: [event_type_id], references: [event_type_id])
  subject    Subject?  @relation(fields: [subject_id], references: [subject_id])
  class      Class?    @relation(fields: [class_id], references: [class_id])
  creator    User      @relation("CreatedEvents", fields: [created_by], references: [user_id])

  @@index([subject_id])
  @@index([class_id])
  @@index([event_type_id])
  @@index([created_by])
}

model Room {
  room_id     Int     @id @default(autoincrement())
  title       String
  capacity    Int
  description String?
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reservations Reservation[]
  // roomFeatures RoomFeature[]
  subjectRooms SubjectRoom[]
}

model SubjectRoom {
  subject_room_id Int @id @default(autoincrement())
  priority        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  room_id    Int
  subject_id Int

  subject Subject @relation(fields: [subject_id], references: [subject_id])
  room    Room    @relation(fields: [room_id], references: [room_id])

  @@index([room_id])
  @@index([subject_id])
  @@unique([subject_id, room_id])
}

