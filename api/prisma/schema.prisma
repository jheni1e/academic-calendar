model Event {
  event_id      Int     @id @default(autoincrement())
  title         String
  description   String?
  // event_type_id Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // subject_id    Int?
  subject_instructor_id Int?
  class_id      Int?
  recurrence_id Int?
  created_by    Int

  start_date DateTime
  end_date   DateTime
  event_type EventType

  is_blocked Boolean @default(false)

  status EventStatus @default(SCHEDULED)
  participations Participation[]
  reservation    Reservation?
  recurrence     Recurrence?     @relation(fields: [recurrence_id], references: [recurrence_id])
  subject_instructor SubjectInstructor?  @relation(fields: [subject_instructor_id], references: [subject_instructor_id])

  // subject    Subject?  @relation(fields: [subject_id], references: [subject_id])
  class      Class?    @relation(fields: [class_id], references: [class_id])
  creator    User      @relation("CreatedEvents", fields: [created_by], references: [user_id])

  // @@index([subject_id])
  // @@index([event_type_id])
  @@index([subject_instructor_id])
  @@index([class_id])
  @@index([created_by])
  @@index([is_blocked])
  @@index([recurrence_id])
  @@index([start_date, end_date])
  @@index([status])
  @@index([class_id, start_date])
}

model Recurrence {
  recurrence_id Int                 @id @default(autoincrement())
  series_name   String              

  repeat_until DateTime?
  occurrences  Int?
  created_by   Int

  monday    Boolean @default(false)
  tuesday   Boolean @default(false)
  wednesday Boolean @default(false)
  thursday  Boolean @default(false)
  friday    Boolean @default(false)
  // saturday  Boolean @default(false)
  // sunday    Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator User    @relation(fields: [created_by], references: [user_id])
  events  Event[]

  @@index([created_by])
}

